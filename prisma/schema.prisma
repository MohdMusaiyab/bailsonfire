generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// USERS & NEXTAUTH (JWT Strategy)
// ─────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String? // Added for Credentials provider (hashed)
  accounts      Account[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  comments  Comment[]
  likes     Like[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// ─────────────────────────────────────────
// CUSTOM OTP VERIFICATION
// ─────────────────────────────────────────
enum OTPType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

model VerificationOTP {
  id        String   @id @default(cuid())
  email     String
  otp       String
  type      OTPType
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@unique([email, type]) // Ensures only 1 active OTP of each type per user
}

// ─────────────────────────────────────────
// AI INGESTION & INTERACTION MODELS
// ─────────────────────────────────────────

model Match {
  id               String   @id @default(cuid())
  externalId       String   @unique // The "Gatekeeper" (e.g., ipl-2026-csk-rcb-20260409)
  homeTeam         String
  awayTeam         String
  scoreSummary     String
  matchDate        DateTime
  venue            String
  winner           String?
  loser            String?
  playerOfTheMatch String?
  keyMoments       String[]
  scorecard        Json?

  summaries Summary[]
  comments  Comment[]
  likes     Like[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Summary {
  id      String @id @default(cuid())
  matchId String
  content String @db.Text
  aiModel String // e.g., gemini-2.0-flash

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Comment {
  id      String @id @default(cuid())
  content String @db.Text
  userId  String
  matchId String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Like {
  id      String @id @default(cuid())
  userId  String
  matchId String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, matchId]) // A user can only like a match once
}
